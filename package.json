{
  "name": "grind",
  "private": true,
  "scripts": {
    "backend:start": "npm run start --workspace apps/backend",
    "contest-ws:start": "npm run start --workspace apps/contest-websocket-server",
    "publisher:start": "npm run start --workspace apps/publisher",
    "worker:start": "npm run start --workspace apps/worker",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0"
  }
}
